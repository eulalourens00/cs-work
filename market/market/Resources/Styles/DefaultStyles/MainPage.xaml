<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="market.Resources.Styles.DefaultStyles.MainPage">


    <Color x:Key="Background">#F5F6F1</Color>
    
    
    <!--//frame for clothes-->
    <Style x:Key="FrameForClothes" TargetType="Frame">
        <Setter  Property="CornerRadius" Value="20"/>
        <Setter Property="BackgroundColor" Value="#E6E5E3"/>
    </Style>

    <Style x:Key="Rating" TargetType="Frame">
        <Setter Property="CornerRadius" Value="11"/>
        <Setter Property="BackgroundColor" Value="White"/>
    </Style>

    
</ResourceDictionary>