<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Style x:Key="BigCard" TargetType="Image">
        <Setter Property="Aspect" Value="AspectFill"/>
        <Setter Property="MaximumHeightRequest" Value="326"/>
        <Setter Property="MaximumWidthRequest" Value="350"/>
    </Style>

    <Style x:Key="BigFrame" TargetType="Frame">
        <Setter Property="BorderColor" Value="Transparent"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="CornerRadius" Value="20"/>
        <Setter Property="MaximumHeightRequest" Value="326"/>
        <Setter Property="MaximumWidthRequest" Value="350"/>
    </Style>

    <Style x:Key="MiniCards" TargetType="Frame">
        <Setter Property="BorderColor" Value="White"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="MaximumHeightRequest" Value="110"/>
        <Setter Property="MaximumWidthRequest" Value="110"/>
    </Style>

    <Style x:Key="SavedCard" TargetType="Image">
        <Setter Property="Aspect" Value="AspectFill"/>
        <Setter Property="MaximumHeightRequest" Value="25"/>
        <Setter Property="MaximumWidthRequest" Value="25"/>
    </Style>

    <Style x:Key="ChangedColorFrame" TargetType="Frame">
        <Setter Property="MaximumHeightRequest" Value="122"/>
        <Setter Property="MaximumWidthRequest" Value="170"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="BorderColor" Value="Transparent"/>
        <Setter Property="BackgroundColor" Value="#F5F5F5"/>
    </Style>

    <Style x:Key="NameCard" TargetType="Label">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="MaximumWidthRequest" Value="120"/>
        <Setter Property="TextColor" Value="Black"/>
    </Style>

    <Style x:Key="CheckOutFrame" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="#EB6434"/>
        <Setter Property="BorderColor" Value="Transparent"/>
        <Setter Property="CornerRadius" Value="15"/>
        <Setter Property="MaximumHeightRequest" Value="82"/>
        <Setter Property="MaximumWidthRequest" Value="350"/>
    </Style>
</ResourceDictionary>