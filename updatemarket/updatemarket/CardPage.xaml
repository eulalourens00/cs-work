<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="updatemarket.CardPage"
             BackgroundColor="{StaticResource BackgroundCC}">
    <ScrollView Background="Transparent">
        <VerticalStackLayout>
            <!--ЛОГО И КНОПКИ МЕНЮ - КОРЗИНА-->

            <Grid Padding="15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ImageButton Style="{StaticResource ImgBtn}" MaximumHeightRequest="65" MaximumWidthRequest="65" Source="baacck.png"  Grid.Column="0"  />

                <Image Grid.Column="1" Source="logo.png" Style="{StaticResource Logo}" />

                <ImageButton Style="{StaticResource ImgBtn}" Grid.Column="2" Source="bgg.png"/>
            </Grid>

            <!--ОГРОМНАЯ ФОТКА ЛЕЕЕЕ-->
            <VerticalStackLayout Padding="10">

                <!--писец 1-->
                <Frame Style="{StaticResource BigFrame}" >
                    <Grid>
                        <Image Style="{StaticResource BigCard}" Source="main.png"></Image>

                        <!--жестко оцениваем-->
                        <Frame Style="{StaticResource RatingFrame}" >

                            <HorizontalStackLayout Padding="10,0,0,0" Spacing="5">
                                <Image Source="star.png" Style="{StaticResource Star}"/>

                                <Label Style="{StaticResource RatingCount}"/>
                            </HorizontalStackLayout>
                        </Frame>
                        <Frame Style="{StaticResource bagFrame}">
                            <Image Source="baag.png" Style="{StaticResource Bag}"/>
                        </Frame>
                    </Grid>
                </Frame>

                <!--МИНИ-->
                <Grid ColumnSpacing="10" HorizontalOptions="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Frame Grid.Column="0" Style="{StaticResource MiniCards}" >
                        <Grid>
                            <Image Source="first.png"  Aspect="AspectFill" />
                        </Grid>
                    </Frame>
                    <Frame Grid.Column="1" Style="{StaticResource MiniCards}">
                        <Grid>
                            <Image Source="second.png"  Aspect="AspectFill" />
                        </Grid>
                    </Frame>
                    <Frame Grid.Column="2" Style="{StaticResource MiniCards}">
                        <Grid>
                            <Image Source="third.png"  Aspect="AspectFill"/>
                        </Grid>
                    </Frame>
                </Grid>
            </VerticalStackLayout>

            <!--У НАС ТУТ ТЕПЛО-->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Frame Grid.Column="0" BorderColor="Transparent" BackgroundColor="Transparent">
                    <Label Text="Avoine Hooded&#10;Quilted Jacket" TextColor="Black" FontSize="22"
                     HorizontalTextAlignment="Start" Padding="10"/>
                </Frame>
                
                <Frame Grid.Column="1" BorderColor="Transparent" BackgroundColor="Transparent">
                    <Image Style="{StaticResource SavedCard}" Source="tag.png" ></Image>
                </Frame>
            </Grid>

            <!--КУБИКИ -->
            <Grid Padding="15" ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Frame Grid.Column="0" Style="{StaticResource ChangedColorFrame}">
                    <Grid >
                        <Label Text="CHOOSE&#10;COLOR" Style="{StaticResource NameCard}"/>

                        <Label Style="{StaticResource ColorZelox}" TextColor="Black" ></Label>

                        <Frame Margin="0,45,0,0" BorderColor="Transparent" BackgroundColor="#000000"
                                   Padding="5" HeightRequest="32" WidthRequest="110" HorizontalOptions="Start">
                            <HorizontalStackLayout Spacing="9">

                                <Label Text="BEIGE" TextColor="#FFFFFF" FontSize="12"/>

                                <Frame HeightRequest="16" WidthRequest="37" BackgroundColor="#EFEEEA" BorderColor="Transparent"/>

                            </HorizontalStackLayout>
                        </Frame>

                    </Grid>
                </Frame>

                <Frame Grid.Column="2" Style="{StaticResource ChangedColorFrame}" BackgroundColor="Black">

                    <Grid Padding="5">
                        <Label Text="CHOOSE&#10;SIZE" TextColor="#FFFFFF" Style="{StaticResource NameCard}" BackgroundColor="Black"/>

                        <Label Style="{StaticResource ColorZelox}" ></Label>

                        <Frame Margin="0,45,0,0" BorderColor="Transparent" BackgroundColor="white"
                                   Padding="5" HeightRequest="30" WidthRequest="110" HorizontalOptions="Start">
                            
                                <Label Text="MEDIUM" TextColor="black" FontSize="12"/>

                        </Frame>

                    </Grid>
                </Frame>
            </Grid>

            <Frame  Style="{StaticResource CheckOutFrame}"  Margin="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Label Grid.Column="0" Text="CHEKOUT" TextColor="white"></Label>

                    <Label Grid.Column="1" Text="$ 1500" TextColor="black" HorizontalOptions="End"></Label>
                </Grid>

            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>