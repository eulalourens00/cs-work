<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="updatemarket.ChangedNumberPage"
             BackgroundColor="{StaticResource BackgroundCC}">

    <VerticalStackLayout Spacing="20" Padding="30">

        <Label Text="Введите число" FontSize="18"  HorizontalOptions="Center" TextColor="Black" />

        <Entry x:Name="InputEntry" Keyboard="Numeric" FontSize="16"
               BackgroundColor="White" PlaceholderColor="Gray" TextColor="Black"/>

        <Button Text="Отразить" Clicked="OnMirrorClicked"
                BackgroundColor="#FF69B4" TextColor="White"
                FontSize="16" CornerRadius="10"/>

        <Label x:Name="ResultLabel" FontSize="24"
               HorizontalOptions="Center" TextColor="Black" IsVisible="False"/>

        <Image Source="mim.jpg"></Image>
    </VerticalStackLayout>
</ContentPage>
