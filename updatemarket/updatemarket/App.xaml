<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:updatemarket"
             x:Class="updatemarket.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
                <ResourceDictionary Source="/Resources/Styles/DefStyles/DefMainPage.xaml"/>
                <ResourceDictionary Source="/Resources/Styles/DefStyles/DefCardpage.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style TargetType="Label">
                <Setter Property="FontFamily" Value="MonumentExtended"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
